            { id: 3, question: "Lá cây trinh nữ cụp lại khi chạm vào là", options: ["A. Hướng động", "B. Ứng động", "C. Hướng sáng", "D. Hướng nước"], correct: 1 },
            { id: 4, question: "Hoocmon tham gia chủ yếu trong hướng sáng là", options: ["A. GA", "B. Auxin", "C. ABA", "D. Cytokinin"], correct: 1 },
            { id: 5, question: "Hướng tiếp xúc thường thấy ở", options: ["A. Rễ lúa", "B. Thân ngô", "C. Tua cuốn cây bầu", "D. Lá mía"], correct: 2 }
        ];

        // DỮ LIỆU ĐÚNG/SAI
        const dungsaiData = [
            { id: 1, question: "Cho các nhận định sau về hướng động:", statements: [
                "a) Hướng động là phản ứng sinh trưởng của thực vật trước tác nhân kích thích có định hướng.",
                "b) Hướng sáng luôn là phản ứng dương ở mọi bộ phận của cây.",
                "c) Rễ cây thường có hướng trọng lực dương.",
                "d) Hướng hóa chỉ xảy ra ở rễ cây."
            ], correct: [true, false, true, false] }
        ];

        // BIẾN ĐẾM
        let tnAnswers = new Array(tracnghiemData.length).fill(null);
        let dsAnswers = {};

        // RENDER TRẮC NGHIỆM
        function renderTracNghiem() {
            const container = document.getElementById('tracnghiemContainer');
            let html = '';
            tracnghiemData.forEach((q, index) => {
                html += `
                    <div class="question-card">
                        <div class="card-header">
                            <div class="question-number">${q.id}</div>
                            <div class="question-text">${q.question}</div>
                        </div>
                        <div class="card-body">
                            <div class="options">
                                ${q.options.map((opt, optIdx) => `
                                    <label class="option">
                                        <input type="radio" name="tn_${q.id}" value="${optIdx}" onchange="saveTN(${index}, ${optIdx})">
                                        <span>${opt}</span>
                                    </label>
                                `).join('')}
                            </div>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        // RENDER ĐÚNG/SAI
        function renderDungSai() {
            const container = document.getElementById('dungsaiContainer');
            let html = '';
            dungsaiData.forEach(q => {
                html += `
                    <div class="question-card">
                        <div class="card-header">
                            <div class="question-number">Đ/S ${q.id}</div>
                            <div class="question-text">${q.question}</div>
                        </div>
                        <div class="card-body">
                            ${q.statements.map((stmt, idx) => `
                                <div class="statement-item">
                                    <div class="statement-text">${stmt}</div>
                                    <div class="statement-options">
                                        <label class="statement-option">
                                            <input type="radio" name="ds_${q.id}_${idx}" value="true" onchange="saveDS(${q.id}, ${idx}, true)"> ĐÚNG
                                        </label>
                                        <label class="statement-option">
                                            <input type="radio" name="ds_${q.id}_${idx}" value="false" onchange="saveDS(${q.id}, ${idx}, false)"> SAI
                                        </label>
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        // LƯU ĐÁP ÁN TRẮC NGHIỆM
        window.saveTN = function(index, value) {
            tnAnswers[index] = value;
            updateProgress();
        }

        // LƯU ĐÁP ÁN ĐÚNG/SAI
        window.saveDS = function(id, stt, value) {
            if (!dsAnswers[id]) dsAnswers[id] = {};
            dsAnswers[id][stt] = value;
            updateProgress();
        }

        // CẬP NHẬT PROGRESS
        function updateProgress() {
            let tnCount = tnAnswers.filter(a => a !== null).length;
            let dsCount = 0;
            
            Object.values(dsAnswers).forEach(item => {
                dsCount += Object.keys(item).length;
            });

            const total = tracnghiemData.length + (dungsaiData.length * 4);
            const done = tnCount + dsCount;
            const percent = Math.round((done / total) * 100);
            
            document.getElementById('progressFill').style.width = percent + '%';
            document.getElementById('progressPercent').textContent = percent + '%';
            document.getElementById('progressText').textContent = done + '/' + total + ' câu';
        }

        // NỘP BÀI
        window.submitAll = function() {
            // TÍNH ĐIỂM TRẮC NGHIỆM
            let tnCorrect = 0;
            tnAnswers.forEach((ans, idx) => {
                if (ans === tracnghiemData[idx].correct) tnCorrect++;
            });

            // TÍNH ĐIỂM ĐÚNG/SAI
            let dsCorrect = 0;
            let wrongList = [];

            dungsaiData.forEach(q => {
                if (dsAnswers[q.id]) {
                    for (let i = 0; i < 4; i++) {
                        if (dsAnswers[q.id][i] === q.correct[i]) {
                            dsCorrect++;
                        } else {
                            wrongList.push(`Câu ${q.id}.${String.fromCharCode(97 + i)}`);
                        }
                    }
                }
            });

            // HIỂN THỊ KẾT QUẢ
            document.getElementById('tnScore').textContent = `${tnCorrect}/15`;
            document.getElementById('dsScore').textContent = `${dsCorrect}/8`;
            document.getElementById('resultScore').textContent = `${tnCorrect + dsCorrect}/23`;

            let wrongHtml = '<strong>Câu sai:</strong><br>';
            if (wrongList.length === 0) {
                wrongHtml += '🎉 Xuất sắc! Không có câu sai!';
            } else {
                wrongHtml += wrongList.join('<br>');
            }
            document.getElementById('wrongAnswers').innerHTML = wrongHtml;

            document.getElementById('resultModal').classList.add('show');
        }

        // ĐÓNG KẾT QUẢ
        window.closeResult = function() {
            document.getElementById('resultModal').classList.remove('show');
        }

        // POPUP DONATE
        window.showDonatePopup = function() {
            document.getElementById('donatePopup').classList.add('show');
        }

        window.closeDonatePopup = function() {
            document.getElementById('donatePopup').classList.remove('show');
        }

        // KHỞI TẠO
        renderTracNghiem();
        renderDungSai();
    </script>
</body>
</html>
